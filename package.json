{
	"name": "itcb-testing",
	"description": "UI E2E Testing for ITCB Website",
	"version": "1.0.0",
	"main": "index.js",
	"type": "module",
	"author": "Netanel Harush",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/ITCB-2/ITCB-Testing/issues"
	},
	"homepage": "https://github.com/ITCB-2/ITCB-Testing#readme",
	"scripts": {
		"build": "docker compose build",
		"pre-commit": "lint-staged",
		"prepare": "husky",
		"quality:fix": "npm run type-check && prettier --write . && eslint . --fix",
		"quality:check": "npm run type-check && prettier --check . && eslint .",
		"type-check": "tsc --noEmit",
		"trigger-ci": "git commit --allow-empty -m \"trigger CI workflows for testing\" && git push",
		"report": "playwright show-report",
		"codegen": "playwright codegen",
		"test": "npx playwright test",
		"test:sanity": "TEST_TAGS='@sanity' npx playwright test",
		"test:nightly": "TEST_TAGS='@nightly' npx playwright test"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ITCB-2/ITCB-Testing.git"
	},
	"keywords": [
		"playwright",
		"testing",
		"typescript",
		"ui testing"
	],
	"devDependencies": {
		"@faker-js/faker": "^10.4.0",
		"@playwright/test": "^1.58.2",
		"@eslint/js": "^9.39.2",
		"@eslint/json": "^1.0.0",
		"@eslint/markdown": "^7.5.1",
		"@types/node": "^25.5.0",
		"husky": "^9.1.7",
		"eslint": "^9.39.2",
		"jiti": "^2.6.1",
		"lint-staged": "^16.4.0",
		"prettier": "3.8.1",
		"ts-node": "^10.9.2",
		"typescript-eslint": "^8.54.0",
		"typescript": "^5.9.3"
	},
	"lint-staged": {
		"*.{js,ts,mjs,cjs,mts,cts}": "eslint --cache --fix",
		"*.{js,ts,css,md,json}": "prettier --write"
	}
}
